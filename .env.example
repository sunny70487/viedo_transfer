# whisper_transfer — local development environment variables.
#
# Copy to .env (the dev-setup command does this automatically on first run):
#   cp .env.example .env         # macOS / Linux
#   Copy-Item .env.example .env  # Windows PowerShell
#
# All variables below are OPTIONAL — the app boots with defaults if .env is
# empty. Mark a variable "required" only if a specific feature needs it.

# ---- Secrets ---------------------------------------------------------------

# Hugging Face access token. Required ONLY for the speaker diarization
# feature (pyannote.audio) which uses gated models. ASR, subtitle editing,
# and LLM enhancement work without it.
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# ---- Database --------------------------------------------------------------

# SQLAlchemy database URL. Leave unset to use the default SQLite file
# ./tasks.db (recommended for local dev). The Docker compose stack overrides
# this to a postgres URL automatically — do not set it here unless you know
# you want to point dev at a remote DB.
# DATABASE_URL=sqlite:///./tasks.db

# ---- Transcription runtime -------------------------------------------------

# Maximum concurrent transcription workers. Leave unset for auto-detection:
#   GPU → max(2, total_VRAM_GB / 2), capped at 3 × GPU count
#   CPU → min(4, cores / 2)
# Override only if you have specific throughput or memory constraints.
# MAX_TRANSCRIPTION_WORKERS=

# ---- Model caches ----------------------------------------------------------

# Override where ASR models (ModelScope, Hugging Face hub) are downloaded.
# Defaults to each library's per-user cache directory; set these to share
# downloads across multiple projects or to place them on a larger disk.
# MODELSCOPE_CACHE=
# HF_HOME=
# HUGGINGFACE_HUB_CACHE=
